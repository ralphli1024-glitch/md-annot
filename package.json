{
  "name": "md-annot",
  "version": "0.1.0",
  "description": "MDAnnot —— Obsidian Markdown 批注插件。在 Markdown 上留下你的阅读痕迹——高亮、划线、批注，不改原文。",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run"
  },
  "keywords": ["obsidian", "plugin", "annotation", "handwriting"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.0",
    "obsidian": "^1.5.0",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
